# Authentication mode
# strict - Per-request OAuth credentials required via HTTP headers (x-salesforce-access-token etc.)
# oauth  - Shared connection using OAuth 2.0 Client Credentials flow; no per-request headers needed
MCP_AUTH_MODE=strict                  # strict | oauth
MCP_CONNECTION_CACHE_TTL=300000       # Connection cache TTL in milliseconds (5 minutes)

# Required only when MCP_AUTH_MODE=oauth
# OAUTH_CLIENT_ID=<your-connected-app-client-id>
# OAUTH_CLIENT_SECRET=<your-connected-app-client-secret>
# SALESFORCE_INSTANCE_URL=https://your-org.my.salesforce.com

# Logging
MCP_LOG_LEVEL=INFO                    # ERROR|WARN|INFO|DEBUG|VERBOSE
MCP_LOG_TIMESTAMPS=true               # Enable timestamps in logs