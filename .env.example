# ---------------------------------------------------------------------------
# Salesforce MCP Server - environment configuration
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in values as needed.
# No Salesforce credentials belong here - they arrive per-request via the
# standard HTTP Authorization: Bearer header. Only server behaviour is
# configured here.
# ---------------------------------------------------------------------------

# Salesforce identity endpoint — optional override for multi-org servers.
# By default the server auto-discovers the org instance URL by trying
# login.salesforce.com first (production), then test.salesforce.com (sandbox).
# Set this only if your org has "Prevent Login from login.salesforce.com"
# enabled in Setup → Security → Session Settings (My Domain login restriction).
# Example: SALESFORCE_LOGIN_URL=https://myorg.my.salesforce.com
# SALESFORCE_LOGIN_URL=

# Public URL of this server (used in OAuth protected resource metadata)
# Must match the URL clients use to reach the /mcp endpoint.
MCP_SERVER_URL=https://salesforce-mcp-server-org.up.railway.app

# OAuth scopes advertised in the WWW-Authenticate header (on 401) and in the
# /.well-known/oauth-protected-resource endpoint (RFC 9728 scopes_supported).
# Must match the scopes enabled on your Salesforce Connected App.
# Space-separated list. Defaults to the recommended minimum set.
#
# Required Connected App OAuth settings (Setup → App Manager → Edit → OAuth Settings):
#   Access and manage your data (api)
#   Access unique user identifiers (openid)          ← needed for userinfo endpoint
#   Access the identity URL service (id)                ← needed to call userinfo endpoint
#   Perform requests at any time (refresh_token, offline_access)
#   Access custom permissions (web)
MCP_OAUTH_SCOPES=api refresh_token offline_access web openid id

# Additional paths that mirror /.well-known/oauth-protected-resource.
# Useful when clients construct the well-known URL differently (e.g. appending /mcp).
# Comma-separated list. Leave empty to disable. Defaults to the /mcp suffix variant.
MCP_OAUTH_WELL_KNOWN_ALIASES=/.well-known/oauth-protected-resource/mcp

# Cache TTL for proxied authorization server metadata (milliseconds, default 1 hour).
# The server fetches Salesforce's /.well-known/openid-configuration and caches it
# at /.well-known/oauth-authorization-server for client discovery.
# MCP_AUTH_SERVER_METADATA_CACHE_TTL=3600000

# Server transport
MCP_SERVER_PORT=3000              # HTTP port the server listens on

# Instance URL cache TTL in milliseconds (default 5 minutes)
MCP_CONNECTION_CACHE_TTL=300000

# Logging
MCP_LOG_LEVEL=DEBUG                # ERROR | WARN | INFO | DEBUG | VERBOSE
MCP_LOG_TIMESTAMPS=true           # Include ISO-8601 timestamps in log lines
