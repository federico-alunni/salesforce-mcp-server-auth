# ---------------------------------------------------------------------------
# Salesforce MCP Server - environment configuration
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in values as needed.
# No Salesforce credentials belong here - they arrive per-request via the
# standard HTTP Authorization: Bearer header. Only server behaviour is
# configured here.
# ---------------------------------------------------------------------------

# Salesforce identity endpoint
# The server calls GET {SALESFORCE_LOGIN_URL}/services/oauth2/userinfo to
# discover the org instance URL from the Bearer token on every tool request.
#   Production: https://login.salesforce.com  (default, can be omitted)
#   Sandbox:    https://test.salesforce.com
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# Public URL of this server (used in OAuth protected resource metadata)
# Must match the URL clients use to reach the /mcp endpoint.
MCP_SERVER_URL=https://salesforce-mcp-server-org.up.railway.app

# OAuth scopes advertised in the WWW-Authenticate header (on 401) and in the
# /.well-known/oauth-protected-resource endpoint (RFC 9728 scopes_supported).
# Must match the scopes enabled on your Salesforce Connected App.
# Space-separated list. Defaults to the recommended minimum set.
MCP_OAUTH_SCOPES=api refresh_token offline_access web openid

# Redirect URIs advertised in the /.well-known/oauth-protected-resource endpoint
# (RFC 9728 redirect_uris). Tells OAuth clients (e.g. VS Code) which callback
# URLs to use, preventing fallback to http://127.0.0.1 loopback URLs that
# Salesforce External Client Apps reject.
# Space-separated list.
MCP_REDIRECT_URIS=https://vscode.dev/redirect https://memo-librechat.up.railway.app/api/mcp/salesforce/oauth/callback

# Server transport
MCP_SERVER_PORT=3000              # HTTP port the server listens on

# Instance URL cache TTL in milliseconds (default 5 minutes)
MCP_CONNECTION_CACHE_TTL=300000

# Logging
MCP_LOG_LEVEL=INFO                # ERROR | WARN | INFO | DEBUG | VERBOSE
MCP_LOG_TIMESTAMPS=true           # Include ISO-8601 timestamps in log lines
