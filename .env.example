# ---------------------------------------------------------------------------
# Salesforce MCP Server — Environment Configuration
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in values as needed.
# ---------------------------------------------------------------------------

# ==========================================================================
# AUTH MODE (feature flag for migration)
# ==========================================================================
# "local"  — MCP clients authenticate to THIS server (new architecture)
# "legacy" — MCP clients authenticate directly to Salesforce (old behavior)
MCP_AUTH_MODE=local

# ==========================================================================
# Server
# ==========================================================================
MCP_SERVER_PORT=3000
MCP_SERVER_URL=http://localhost:3000

# ==========================================================================
# Module A — MCP Auth (local mode only)
# ==========================================================================
# REQUIRED in local mode: random string ≥32 chars for JWT signing
MCP_JWT_SECRET=change-me-to-a-random-string-of-at-least-32-characters

# JWT issuer/audience (defaults to MCP_SERVER_URL)
# MCP_JWT_ISSUER=
# MCP_JWT_AUDIENCE=

# Access token lifetime in seconds (default 1 hour)
MCP_ACCESS_TOKEN_TTL=3600

# Authorization code lifetime in seconds (default 5 minutes)
MCP_AUTH_CODE_TTL=300

# Comma-separated list of allowed client IDs, or * for any
MCP_ALLOWED_CLIENT_IDS=*

# Scopes advertised in OAuth metadata
MCP_OAUTH_SCOPES=mcp:tools mcp:read

# ==========================================================================
# Module B — Salesforce Connection (local mode)
# ==========================================================================
# Connected App credentials for YOUR backend → Salesforce link
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_OAUTH_SCOPES=api refresh_token offline_access web openid id

# ==========================================================================
# Storage & Security
# ==========================================================================
# Directory for file-based storage (users, connections)
MCP_DATA_DIR=.data

# 64-char hex string for AES-256-GCM encryption of stored tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, tokens are stored in plaintext (development only!)
MCP_ENCRYPTION_KEY=

# ==========================================================================
# Legacy mode settings (MCP_AUTH_MODE=legacy)
# ==========================================================================
# MCP_LEGACY_OAUTH_SCOPES=api refresh_token offline_access web openid id
# MCP_OAUTH_WELL_KNOWN_ALIASES=/.well-known/oauth-protected-resource/mcp
# MCP_AUTH_SERVER_METADATA_CACHE_TTL=3600000

# ==========================================================================
# Logging
# ==========================================================================
MCP_LOG_LEVEL=DEBUG
MCP_LOG_TIMESTAMPS=true

# Instance URL cache TTL in milliseconds (default 5 minutes)
MCP_CONNECTION_CACHE_TTL=300000
