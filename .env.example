# Authentication mode - controls which per-request header styles the server accepts
#
#  strict  - Only accepts per-request access-token headers:
#              x-mcp-auth-mode: strict  (or omit, default)
#              x-salesforce-access-token   (required)
#              x-salesforce-instance-url   (required)
#              x-salesforce-username       (optional)
#              x-salesforce-user-id        (optional)
#
#  oauth   - Only accepts per-request client-credentials headers:
#              x-mcp-auth-mode: oauth      (required)
#              x-salesforce-client-id      (required)
#              x-salesforce-client-secret  (required)
#              x-salesforce-instance-url   (required)
#
#  both    - Accepts either mode above per-request.
#
MCP_AUTH_MODE=strict                  # strict | oauth | both
MCP_CONNECTION_CACHE_TTL=300000       # Connection cache TTL in milliseconds (5 minutes)

# No org credentials in env — all auth credentials are supplied as per-request headers.

# Logging
MCP_LOG_LEVEL=INFO                    # ERROR|WARN|INFO|DEBUG|VERBOSE
MCP_LOG_TIMESTAMPS=true               # Enable timestamps in logs